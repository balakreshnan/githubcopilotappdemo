# ---- Microsoft Foundry (Azure AI Foundry) connection ----
# Project endpoint, e.g. https://<your-resource>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=

# Identify the main / orchestrator agent EITHER by name OR by id.
# Name is matched (case-insensitive) against the agents in your project.
MAIN_AGENT_NAME=RFP Agent
# MAIN_AGENT_ID=asst_xxxxxxxxxxxx

# Optional: connected sub-agents, by name or by id (comma-separated).
# These are only used to label/list the team; sub-agents are also auto-discovered
# from the orchestrator's run steps at runtime.
# CONNECTED_AGENT_NAMES=Requirements Analyst,Compliance Reviewer,Pricing Estimator
# CONNECTED_AGENT_IDS=asst_aaa,asst_bbb

# Optional: model deployment name (informational / display only)
MODEL_DEPLOYMENT=

# ---- App behavior ----
# Set to false to call the real Foundry project. true serves canned responses (no Azure auth).
USE_MOCK=false

# Comma-separated list of allowed CORS origins for the frontend dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
