# ---- Microsoft Foundry (Azure AI Foundry) connection ----
# Project endpoint, e.g. https://<your-resource>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=

# The main / orchestrator agent ID that fans out to connected sub-agents
MAIN_AGENT_ID=

# Optional: comma-separated connected sub-agent IDs (used to label/list them).
# If omitted, sub-agents are discovered from run steps at runtime.
CONNECTED_AGENT_IDS=

# Optional: model deployment name (informational / display only)
MODEL_DEPLOYMENT=

# ---- App behavior ----
# When true, the backend serves canned multi-agent responses and needs no Azure auth.
USE_MOCK=true

# Comma-separated list of allowed CORS origins for the frontend dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
